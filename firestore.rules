rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN' || 
         request.auth.token.email == 'harsheenkour19@gmail.com' ||
         request.auth.token.email == 'harsheenkour@hotmail.com' ||
         request.auth.token.email == '2023a1r070@mietjammu.in');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation helpers
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt']) &&
             data.email is string && data.email.size() <= 128 &&
             data.role in ['DONOR', 'RECEIVER', 'NGO', 'DELIVERY', 'ADMIN'] &&
             data.createdAt is timestamp;
    }

    function isValidDelivery(data) {
      return data.keys().hasAll(['status', 'donorId', 'createdAt']) &&
             (data.keys().hasAll(['medicineName']) || data.keys().hasAll(['name'])) &&
             data.status in ['SCHEDULED', 'IN_TRANSIT', 'DELIVERED', 'CANCELLED', 'VERIFIED'] &&
             data.donorId is string &&
             data.createdAt is timestamp &&
             (data.get('medicineName', 'valid_temp') is string && data.get('medicineName', 'valid_temp').size() <= 200) &&
             (data.get('name', 'valid_temp') is string && data.get('name', 'valid_temp').size() <= 200);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming()) && incoming().role != 'ADMIN'; 
      allow update: if (isOwner(userId) && incoming().role == existing().role) || isAdmin();
      allow list: if isAdmin();
    }

    // Deliveries collection (Donations)
    match /deliveries/{deliveryId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.donorId == request.auth.uid || resource.data.receiverId == request.auth.uid || resource.data.deliveryPartnerId == request.auth.uid));
      allow create: if isSignedIn() && isValidDelivery(incoming());
      allow update: if isAdmin() || (isSignedIn() && (resource.data.donorId == request.auth.uid || resource.data.deliveryPartnerId == request.auth.uid));
      allow delete: if isAdmin();
      allow list: if isAdmin() || (isSignedIn() && (resource.data.donorId == request.auth.uid || resource.data.receiverId == request.auth.uid)); 
    }

    // Requests collection
    match /requests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.receiverId == request.auth.uid);
      allow delete: if isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.receiverId == request.auth.uid);
    }
  }
}
